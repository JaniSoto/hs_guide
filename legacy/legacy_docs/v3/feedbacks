sudo mkdir -p /srv/nextcloud-data

# Get UUID
sudo blkid /dev/nvme1n1p1 
# Add to fstab: UUID=<uuid> /srv/nextcloud-data ext4 defaults 0 2
sudo nano /etc/fstab 

# CRITICAL ORDERING: Mount BEFORE restoring SELinux context
sudo mount -a

# Set and apply SELinux context to the active mount
sudo semanage fcontext -a -t container_file_t "/srv/nextcloud-data(/.*)?"
sudo restorecon -Rv /srv/nextcloud-data

