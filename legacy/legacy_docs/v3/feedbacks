# 1. Update SELinux policy for new SSH port FIRST
sudo semanage port -a -t ssh_port_t -p tcp 53222

# 2. Allow port in Firewalld
sudo firewall-cmd --permanent --add-port=53222/tcp
sudo firewall-cmd --reload

# 3. Harden SSH
sudo tee /etc/ssh/sshd_config.d/99-hardening.conf > /dev/null << 'EOF'
Port 53222
PubkeyAuthentication yes
PasswordAuthentication no
PermitRootLogin no
MaxAuthTries 3
LoginGraceTime 20
AllowUsers YOUR_USERNAME
EOF
# Replace YOUR_USERNAME with your actual user

# 4. Restart SSH and verify syntax
sudo sshd -t
sudo systemctl restart sshd

