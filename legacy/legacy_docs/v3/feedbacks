HEADLESS_CONF="/etc/sddm.conf.d/zzz-headless-server.conf"

rm -f "$HEADLESS_CONF"
mkdir -p /etc/sddm.conf.d
cat > "$LAUNCH_CONF" << SUBEOF
[Autologin]
User=${SDDM_USER}
Session=${KDE_SESSION}
Relogin=false
SUBEOF

systemctl reset-failed sddm
systemctl restart sddm

(
  sleep 7 # Slightly increased to prevent race conditions on slower IO
  rm -f "$LAUNCH_CONF"
  cat > "$HEADLESS_CONF" << SUBEOF
[Autologin]
User=
Session=
Relogin=false
SUBEOF
) &
disown $!
EOF

sudo chmod 755 /usr/local/bin/start-kde.sh
# Ensure ownership
sudo chown root:root /usr/local/bin/start-kde.sh

# Apply Sudoers (Safe Edit)
