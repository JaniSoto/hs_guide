**`stop-session.sh`**
```bash
#!/bin/bash
# stop-session.sh — Terminate the active seat0 session and return to headless idle.
# Normal use: log out via KDE's logout button or Steam's Power menu.
# Location: /usr/local/bin/stop-session.sh (root-owned, not user-writable)
# Usage: ssh -p 22022 user@host 'sudo stop-session.sh'

LAUNCH_CONF="/etc/sddm.conf.d/zz-session-launch.conf"
HEADLESS_CONF="/etc/sddm.conf.d/zzz-headless-server.conf"

log() { echo "[stop-session $(date '+%H:%M:%S')] $*"; }

# --- 1. Cancel any pending restore-headless timers ---
while IFS= read -r unit; do
    log "Cancelling stale timer: $unit"
    systemctl stop "$unit" 2>/dev/null
done < <(systemctl list-units --type=timer --no-legend 2>/dev/null \
         | awk '{print $1}' | grep '^restore-headless-')

# --- 2. Write the headless config immediately ---
rm -f "$LAUNCH_CONF"
printf '[Autologin]\nUser=\nSession=\nRelogin=false\n' > "$HEADLESS_CONF"
log "SDDM configs confirmed in headless state."

# --- 3. Find and terminate the active seat0 user session ---
ACTIVE=$(loginctl list-sessions --no-legend 2>/dev/null \
  | awk '{print $1}' \
  | while read -r sid; do
      seat=$(loginctl  show-session "$sid" -p Seat  --value 2>/dev/null) || continue
      state=$(loginctl show-session "$sid" -p State --value 2>/dev/null) || continue
      class=$(loginctl show-session "$sid" -p Class --value 2>/dev/null) || continue
      [[ "$class" != "user" ]] && continue
      [[ "$seat" == "seat0" ]] && \
      [[ "$state" == "active" || "$state" == "online" ]] && \
        { echo "$sid"; break; }
    done)

if [[ -n "$ACTIVE" ]]; then
    log "Terminating session $ACTIVE on seat0..."
    log "WARNING: All unsaved work in the terminated session is lost."
    loginctl terminate-session "$ACTIVE"
    # Brief pause for the session cgroup to begin unwinding before
    # restarting SDDM.
    sleep 3
else
    log "No active seat0 user session found. Nothing to terminate."
fi

# --- 4. Restart SDDM to release the DRM master lock ---
log "Restarting SDDM to release GPU/DRM lock..."
systemctl reset-failed sddm 2>/dev/null
systemctl restart sddm

# --- 5. Wait for the SDDM greeter to appear on seat0 ---
# When the greeter session (Class=greeter) appears on seat0, SDDM holds
# DRM master — confirming the GPU handover from the previous session is
# complete. The script blocks here and does not return until confirmed.
# This makes timing self-regulating rather than relying on fixed sleeps.
# The additional sleep 3 after confirmation provides a post-greeter GPU
# drain buffer, particularly needed after KDE sessions where kwin_wayland
# releases GPU allocations asynchronously.
log "Waiting for SDDM greeter to initialize (GPU/DRM settle)..."
GREETER_READY=false
for i in $(seq 1 25); do
    sleep 1
    GREETER=$(loginctl list-sessions --no-legend 2>/dev/null \
      | awk '{print $1}' \
      | while read -r sid; do
          seat=$(loginctl  show-session "$sid" -p Seat  --value 2>/dev/null) || continue
          class=$(loginctl show-session "$sid" -p Class --value 2>/dev/null) || continue
          [[ "$class" == "greeter" && "$seat" == "seat0" ]] && \
            { echo "$sid"; break; }
        done)
    if [[ -n "$GREETER" ]]; then
        log "SDDM greeter ready after ${i}s. GPU/DRM fully released."
        GREETER_READY=true
        sleep 3
        break
    fi
done

if [[ "$GREETER_READY" != "true" ]]; then
    log "Warning: SDDM greeter not detected within 25s. GPU state uncertain — proceed with caution."
fi

log "Done. SDDM login screen should be on the physical display."
```

