**`start-kde.sh`**
```bash
#!/bin/bash
# start-kde.sh — Launch a KDE Wayland session on the physical display.
# Refuses if a graphical user session is already active on seat0.
# Location: /usr/local/bin/start-kde.sh (root-owned, not user-writable)
# Usage: ssh -p 22022 user@host 'sudo start-kde.sh'

SDDM_USER="PLACEHOLDER"
KDE_SESSION="plasma"
LAUNCH_CONF="/etc/sddm.conf.d/zz-session-launch.conf"
HEADLESS_CONF="/etc/sddm.conf.d/zzz-headless-server.conf"

log() { echo "[start-kde $(date '+%H:%M:%S')] $*"; }

# --- 1. Cancel any pending restore-headless timers ---
while IFS= read -r unit; do
    log "Cancelling stale timer: $unit"
    systemctl stop "$unit" 2>/dev/null
done < <(systemctl list-units --type=timer --no-legend 2>/dev/null \
         | awk '{print $1}' | grep '^restore-headless-')

# --- 2. Guard: refuse if a seat0 user session is already active ---
ACTIVE=$(loginctl list-sessions --no-legend 2>/dev/null \
  | awk '{print $1}' \
  | while read -r sid; do
      seat=$(loginctl  show-session "$sid" -p Seat  --value 2>/dev/null) || continue
      state=$(loginctl show-session "$sid" -p State --value 2>/dev/null) || continue
      class=$(loginctl show-session "$sid" -p Class --value 2>/dev/null) || continue
      [[ "$class" != "user" ]] && continue
      [[ "$seat" == "seat0" ]] && \
      [[ "$state" == "active" || "$state" == "online" ]] && \
        { echo "$sid"; break; }
    done)

if [[ -n "$ACTIVE" ]]; then
    log "ERROR: A graphical session ($ACTIVE) is already active on seat0."
    log "Log out of the current session first, then re-run this script."
    exit 1
fi

# --- 3. Write the one-shot autologin config ---
rm -f "$HEADLESS_CONF"
mkdir -p /etc/sddm.conf.d
cat > "$LAUNCH_CONF" << EOF
[Autologin]
User=${SDDM_USER}
Session=${KDE_SESSION}
Relogin=false
EOF
log "SDDM autologin config written for KDE Wayland."

# --- 4. Restart SDDM (synchronous — reads LAUNCH_CONF during startup) ---
log "Restarting SDDM..."
systemctl reset-failed sddm 2>/dev/null
systemctl restart sddm
log "KDE Wayland session launching on physical display."

# --- 5. Schedule headless restoration as a system-level transient service ---
# Runs outside the SSH session cgroup — immune to KillUserProcesses=yes.
# --collect: garbage-collects the unit after it finishes.
systemd-run --no-ask-password --collect \
    --unit="restore-headless-$(date +%s)" \
    --on-active=10 \
    /bin/bash -c 'rm -f /etc/sddm.conf.d/zz-session-launch.conf && \
      printf "[Autologin]\nUser=\nSession=\nRelogin=false\n" \
      > /etc/sddm.conf.d/zzz-headless-server.conf'
log "Headless config restoration scheduled in 10 s."
```

