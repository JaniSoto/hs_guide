# ── Container block ────────────────────────────────────────────────────────────
print_containers() {
    local out
    out=$(docker ps -a --format '{{.Names}}#{{.Status}}' 2>/dev/null)
    if [ -z "$out" ]; then
        printf "  ${RED}Docker not running or no containers found.${R}\n"; return
    fi
    printf "%s\n" "$out" | awk -F'#' '{
        name=$1; st=$2
        if      (st~/healthy/)  { dot="\033[1;32m●\033[0m"; tag="healthy"  }
        else if (st~/^Up/)      { dot="\033[1;32m●\033[0m"; tag="up"       }
        else if (st~/starting/) { dot="\033[1;33m●\033[0m"; tag="starting" }
        else if (st~/^Exited/)  { dot="\033[1;31m●\033[0m"; tag="stopped"  }
        else                    { dot="\033[1;33m●\033[0m"; tag=substr(st,1,9) }
        entry=sprintf("  %-36s %s %-9s", name, dot, tag)
        if (NR%2==1) { row=entry }
        else         { printf "%s    %s\n", row, entry; row="" }
    } END { if (row!="") printf "%s\n", row }'
}

# ══════════════════════════════════════════════════════════════════════════════
# Main loop
# ══════════════════════════════════════════════════════════════════════════════
CYCLE=0

while true; do

    # ── CPU Power (RAPL) ──────────────────────────────────────────────────────
    cur_time=$(date +%s%3N)
    elapsed_ms=$(( cur_time - prev_time ))

    if [ -n "$prev_energy" ]; then
        cur_energy=$(cat "$RAPL_FILE" 2>/dev/null)
        delta_uj=$(( cur_energy - prev_energy ))
        (( delta_uj < 0 )) && delta_uj=$(( cur_energy )) # fallback if counter resets

        if (( elapsed_ms > 0 && delta_uj > 0 )); then
            # Convert microjoules to Watts: W = µJ / (ms * 100)  [×10 fixed-point]
            w_x10=$(( delta_uj / (elapsed_ms * 100) ))
            cpu_power="$(( w_x10 / 10 )).$(( w_x10 % 10 ))W"
        fi
        prev_energy=$cur_energy
    fi
    prev_time=$cur_time

    # ── CPU usage (delta since last sample) ───────────────────────────────────
    cur_cs=$(_cpustat)
    read -ra _p <<< "$prev_cs"
    read -ra _c <<< "$cur_cs"
    _pt=0; _ct=0
    for v in "${_p[@]}"; do (( _pt += v )); done
    for v in "${_c[@]}"; do (( _ct += v )); done
    _dt=$(( _ct - _pt )); _di=$(( _c[3] - _p[3] ))
    (( _dt > 0 )) && cpu_pct=$(( 100 * (_dt - _di) / _dt )) || cpu_pct=0
    prev_cs="$cur_cs"

    # ── CPU clock (average across all online cores) ───────────────────────────
    _fsum=0; _fn=0
    for _f in /sys/devices/system/cpu/cpufreq/policy*/scaling_cur_freq; do
        [ -r "$_f" ] || continue
        _fkhz=$(< "$_f")
        (( _fsum += _fkhz, _fn++ ))
    done
    if (( _fn > 0 )); then
        _mhz=$(( _fsum / _fn / 1000 ))
        if (( _mhz >= 1000 )); then
            cpu_freq="$(( _mhz / 1000 )).$(( (_mhz % 1000) / 100 ))GHz"
        else
            cpu_freq="${_mhz}MHz"
        fi
    else cpu_freq="n/a"; fi

    # ── CPU temp ──────────────────────────────────────────────────────────────
    CPU_TEMP=$(sensors 2>/dev/null \
        | grep -E '(Tctl|Tdie|Package id 0)' | head -1 | awk '{print $2}')
    [ -z "$CPU_TEMP" ] && \
        CPU_TEMP=$(sensors 2>/dev/null | grep 'temp1' | head -1 | awk '{print $2}')
    [ -z "$CPU_TEMP" ] && CPU_TEMP="n/a"

    # ── Extra Temps (RAM & NVMe) ──────────────────────────────────────────────
    RAM_TEMP=$(sensors 2>/dev/null | grep -A 2 'spd5118' | awk '/temp1/{print $2; exit}')
    NVME_TEMP=$(sensors 2>/dev/null | grep -A 2 'nvme-pci' | awk '/Composite/{print $2; exit}')

    # ── GPU ───────────────────────────────────────────────────────────────────
    GPU_ROW=""
    if [ -n "$GPU_DEV" ]; then
        # Utilisation
        _gbusy=$(cat "${GPU_DEV}/gpu_busy_percent" 2>/dev/null)
        _gbusy=${_gbusy:-0}

        # Core clock (Hz → MHz)
        _gfhz=${GPU_HWMON:+$(cat "${GPU_HWMON}/freq1_input" 2>/dev/null)}
        if [ -n "$_gfhz" ] && (( _gfhz > 0 )); then
            gpu_freq="$(( _gfhz / 1000000 ))MHz"
        else gpu_freq="n/a"; fi

        # Edge temp (millidegrees → °C)
        _gt=${GPU_HWMON:+$(cat "${GPU_HWMON}/temp1_input" 2>/dev/null)}
        [ -n "$_gt" ] && gpu_temp="+$(( _gt / 1000 ))°C" || gpu_temp="n/a"

        # VRAM (bytes → GiB, or MiB for small cards)
        _vu=$(cat "${GPU_DEV}/mem_info_vram_used"  2>/dev/null)
        _vt=$(cat "${GPU_DEV}/mem_info_vram_total" 2>/dev/null)
        if [ -n "$_vu" ] && [ -n "$_vt" ] && (( _vt > 0 )); then
            _vum=$(( _vu / 1048576 )); _vtm=$(( _vt / 1048576 ))
            if (( _vtm >= 1024 )); then
                _vui=$(( _vum / 1024 )); _vud=$(( (_vum % 1024) * 10 / 1024 ))
                _vti=$(( _vtm / 1024 )); _vtd=$(( (_vtm % 1024) * 10 / 1024 ))
                gpu_vram="${_vui}.${_vud}/${_vti}.${_vtd}GiB VRAM"
            else
                gpu_vram="${_vum}/${_vtm}MiB VRAM"
            fi
        else gpu_vram=""; fi

        # GPU power draw (μW → W, one decimal place)
        _gpw=${GPU_HWMON:+$(cat "${GPU_HWMON}/power1_average" 2>/dev/null)}
        if [ -n "$_gpw" ] && (( _gpw > 0 )); then
            gpu_power="$(( _gpw / 1000000 )).$(( (_gpw % 1000000) / 100000 ))W"
        else gpu_power=""; fi

        GPU_ROW="$(pct_dot "$_gbusy" 70 90) ${_gbusy}%  ${DIM}@${R}  ${gpu_freq}  ${DIM}·${R}  ${gpu_temp}"
        [ -n "$gpu_vram"  ] && GPU_ROW+="  ${DIM}·${R}  ${gpu_vram}"
        [ -n "$gpu_power" ] && GPU_ROW+="  ${DIM}·${R}  ${gpu_power}"
    fi

    # ── Memory ────────────────────────────────────────────────────────────────
    RAM_USED=$(free -h | awk '/^Mem:/{print $3}')
    RAM_TOT=$( free -h | awk '/^Mem:/{print $2}')
    RAM_PCT=$( free    | awk '/^Mem:/{printf "%.0f",$3/$2*100}')
    SWAP_USED=$(free -h | awk '/^Swap:/{print $3}')
    SWAP_TOT=$( free -h | awk '/^Swap:/{print $2}')
    RAM_PCT=${RAM_PCT:-0}

    # ── Display ───────────────────────────────────────────────────────────────
    SEAT0=$(loginctl list-sessions --no-legend 2>/dev/null | awk '$4=="seat0"{print $1;exit}')
    if [ -n "$SEAT0" ]; then
        CLS=$(loginctl show-session "$SEAT0" -p Class --value 2>/dev/null)
        if [ "$CLS" = "greeter" ]; then
            DISP_DOT=$(dot_ok); DISP_ST="idle  ${DIM}SDDM login screen${R}"
        else
            DSK=$(loginctl show-session "$SEAT0" -p Desktop --value 2>/dev/null)
            DISP_DOT=$(dot_warn); DISP_ST="active  ${DIM}${DSK:-session}${R}"
        fi
    else
        DISP_DOT=$(dot_ok); DISP_ST="idle  ${DIM}no display active${R}"
    fi
    if [ -f /etc/sddm.conf.d/zz-session-launch.conf ]; then
        SDDM_DOT=$(dot_warn); SDDM_ST="launch conf present"
    else
        SDDM_DOT=$(dot_ok); SDDM_ST="clean"
    fi

    # ── Storage ───────────────────────────────────────────────────────────────
    OS_S=$(df -h /var 2>/dev/null | awk 'NR==2{print $3" / "$2" ("$5")"}')
    DAT_RAW=$(df -h /var/srv/nextcloud-data 2>/dev/null | awk 'NR==2{print $3" / "$2" ("$5")"}')
    if [ -n "$DAT_RAW" ]; then DAT_DOT=$(dot_ok); DAT_ST="$DAT_RAW"
    else DAT_DOT=$(dot_err); DAT_ST="not mounted"; fi

    # ── Network (fast parts) ──────────────────────────────────────────────────
    SSH_C=$(ss -tn state established 2>/dev/null | grep -c ":22022")

    # ── Systemd ───────────────────────────────────────────────────────────────
    FAIL_N=$(systemctl --failed --no-legend 2>/dev/null | grep -c '.' || true)
    if [ "${FAIL_N:-0}" -gt 0 ]; then
        FAIL_NAMES=$(systemctl --failed --no-legend 2>/dev/null | awk '{printf "%s  ",$2}')
        SYS_DOT=$(dot_err); SYS_ST="${FAIL_N} failed  ${DIM}${FAIL_NAMES}${R}"
    else
        SYS_DOT=$(dot_ok); SYS_ST="healthy"
    fi

    # ── Slow refresh (network/docker — every SLOW_EVERY cycles) ──────────────
    # Skipped on cycle 0 so the first frame renders instantly.
    (( CYCLE > 0 && CYCLE % SLOW_EVERY == 0 )) && refresh_slow

    # ── Timestamps ────────────────────────────────────────────────────────────
    NOW=$(date '+%a %d %b %Y  %H:%M:%S')
    HOST=$(hostname -s)
    UP=$(uptime -p | sed 's/up //')
    LOAD=$(awk '{print $1"  "$2"  "$3}' /proc/loadavg)

    # ── Paint ─────────────────────────────────────────────────────────────────
    printf '\033[H\033[2J'

    printf "%s\n" "$THICK"
    printf "  ${WHT}${BLD}BAZZITE  %-22s${R}  ${DIM}%s${R}\n" "$HOST" "$NOW"
    printf "%s\n" "$THICK"

    row "SYSTEM"   "up $UP  ${DIM}·${R}  load $LOAD"
    row "CPU"      "$(pct_dot "$cpu_pct" 60 85) ${cpu_pct}%  ${DIM}@${R}  ${cpu_freq}  ${DIM}·${R}  ${CPU_TEMP}  ${DIM}·${R}  ${cpu_power}"
    [ -n "$GPU_ROW" ] && \
    row "GPU"      "$GPU_ROW"
    row "MEMORY"   "$(pct_dot "$RAM_PCT" 75 90) RAM $RAM_USED / $RAM_TOT ${DIM}(${RAM_PCT}%)${R}  ${DIM}·${R}  swap $SWAP_USED / $SWAP_TOT${RAM_TEMP:+  ${DIM}·${R}  $RAM_TEMP}"
    row "DISPLAY"  "$DISP_DOT $DISP_ST  ${DIM}·${R}  sddm $SDDM_DOT $SDDM_ST"
    row "STORAGE"  "OS $OS_S  ${DIM}·${R}  data $DAT_DOT $DAT_ST${NVME_TEMP:+  ${DIM}·${R}  $NVME_TEMP}"
    row "NETWORK"  "SSH ${SSH_C} conn  ${DIM}·${R}  F2B ${F2B} banned  ${DIM}·${R}  WAN $WAN_IP"
    row "SYSTEMD"  "$SYS_DOT $SYS_ST"
    row "SERVICES" "NPM $NPM_DOT $NPM_ST  ${DIM}·${R}  Nextcloud $NC_DOT $NC_ST  ${DIM}·${R}  $CERT_DOT $CERT_ST"
    row "BACKUP"   "$BK_DOT $BK_ST"

    printf "\n%s\n" "$THIN"
    printf "  ${BLU}CONTAINERS${R}\n"
    print_containers

    printf "\n%s\n" "$THICK"
    _ns=$(( (SLOW_EVERY - CYCLE % SLOW_EVERY) * REFRESH ))
    printf "  ${DIM}refresh ${REFRESH}s  ·  slow data in ${_ns}s  ·  journalctl -u sshd -f  ·  Ctrl+C to exit${R}\n"
    printf "%s\n" "$THICK"

    CYCLE=$(( CYCLE + 1 ))
    sleep "$REFRESH"

done

