NPM_DOT=$(dot_dim); NPM_ST="–"
NC_DOT=$(dot_dim);  NC_ST="–"
CERT_DOT=$(dot_dim); CERT_ST="–"
BK_DOT=$(dot_dim);  BK_ST="–"

refresh_slow() {
