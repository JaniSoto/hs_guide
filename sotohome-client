#!/bin/bash

# =============================================================================
# Duplicate Instance Prevention & Clean Takeover
# =============================================================================
PID_FILE="/tmp/sotohome.pid"
SCRIPT_NAME=$(basename "$0")

if [ "$1" != "--install" ] && [ "$1" != "--update" ]; then
    if [ -f "$PID_FILE" ]; then
        OLD_PID=$(cat "$PID_FILE" 2>/dev/null)
        if [ -n "$OLD_PID" ] && kill -0 "$OLD_PID" 2>/dev/null; then
            if grep -q "$SCRIPT_NAME" "/proc/$OLD_PID/cmdline" 2>/dev/null; then
                pkill -9 -P "$OLD_PID" 2>/dev/null
                kill -9 "$OLD_PID" 2>/dev/null
            fi
        fi
    fi
    echo "$$" > "$PID_FILE"
    pkill -9 moonlight 2>/dev/null
fi

# =============================================================================
# Configurations & Globals
# =============================================================================
SERVER_IP="192.168.178.139"
VPN_NAME="sotohome"
APP_NAME="sotohome"
WEBHOOK_PORT="9000"
SSH_ALIAS="sotohome"

# Self-Update Config
REPO_USER="JaniSoto"
REPO_NAME="hs_guide"
REPO_BRANCH="main"
SCRIPT_FILE_PATH="sotohome-client"

# Bitrate Config
BITRATE_FILE="$HOME/.config/sotohome_bitrate"
mkdir -p "$HOME/.config"
BITRATE=$(cat "$BITRATE_FILE" 2>/dev/null)
if [ -z "$BITRATE" ] || ! [[ "$BITRATE" =~ ^[0-9]+$ ]]; then
    BITRATE="20000"
    echo "$BITRATE" > "$BITRATE_FILE"
fi

if ! command -v zenity >/dev/null 2>&1; then
    notify-send "Dependency Missing" "Zenity is required for this script but is not installed." 2>/dev/null
    echo "Error: Zenity is required but is not installed." >&2
    exit 1
fi

# =============================================================================
# GUI Helper Functions
# =============================================================================
gui_notify() { notify-send --app-name="SotoHome" "$1" 2>/dev/null; }
gui_error()  { zenity --error --title="SotoHome Error" --text="$1"; }
gui_info()   { zenity --info --title="${2:-SotoHome}" --text="$1" --timeout=${3:-5}; }

# =============================================================================
# CLI Action Functions
# =============================================================================
do_install() {
    local silent_flag="$2"
    local SCRIPT_PATH=$(realpath "$0")
    local DESKTOP_DIR="$HOME/.local/share/applications"
    local DESKTOP_PATH="$DESKTOP_DIR/sotohome.desktop"

    mkdir -p "$DESKTOP_DIR"
    cat <<EOF > "$DESKTOP_PATH"
[Desktop Entry]
Name=SotoHome
Comment=Stream Gaming or KDE
Exec=$SCRIPT_PATH
Icon=applications-games-symbolic
Terminal=false
Type=Application
Categories=Game;Utility;
Actions=AdminMode;ChangeBitrate;GPUControl;UpdateScript;

[Desktop Action AdminMode]
Name=Launch as Admin
Exec=$SCRIPT_PATH --admin

[Desktop Action ChangeBitrate]
Name=Configure Bitrate
Exec=$SCRIPT_PATH --bitrate

[Desktop Action GPUControl]
Name=Configure GPU Power
Exec=$SCRIPT_PATH --gpu

[Desktop Action UpdateScript]
Name=Update Script
Exec=$SCRIPT_PATH --update
EOF
    chmod +x "$DESKTOP_PATH"
    if command -v update-desktop-database >/dev/null 2>&1; then
        update-desktop-database "$DESKTOP_DIR" >/dev/null 2>&1
    fi

    if [ "$silent_flag" != "--silent" ]; then
        gui_info "SotoHome launcher successfully installed!\n\nYou can now find it in your system's application menu." "SotoHome Installer"
    fi
    exit 0
}

do_bitrate() {
    local CURRENT_MBPS=$((BITRATE / 1000))
    local NEW_MBPS=$(zenity --scale --title="Configure Bitrate" \
        --text="Select Moonlight Streaming Bitrate (in Mbps):" \
        --value="$CURRENT_MBPS" --min-value=5 --max-value=150 --step=5)

    if [ -n "$NEW_MBPS" ]; then
        local NEW_KBPS=$((NEW_MBPS * 1000))
        echo "$NEW_KBPS" > "$BITRATE_FILE"
        BITRATE="$NEW_KBPS" # Update runtime state
        gui_notify "Bitrate successfully updated to $NEW_MBPS Mbps."
    fi
}

do_update() {
    local SCRIPT_PATH=$(realpath "$0")
    local UPDATE_URL="https://raw.githubusercontent.com/${REPO_USER}/${REPO_NAME}/${REPO_BRANCH}/${SCRIPT_FILE_PATH}"
    local TEMP_FILE=$(mktemp /tmp/sotohome_update.XXXXXX)

    (
        echo "10"; echo "# Connecting to GitHub..."
        if curl -s -f -L "$UPDATE_URL" -o "$TEMP_FILE"; then
            echo "60"; echo "# Verifying downloaded file..."
            if head -n 1 "$TEMP_FILE" | grep -q "#!/bin/bash"; then
                echo "100"; echo "# Update verified successfully!"
            else
                echo "error"; rm -f "$TEMP_FILE"; exit 1
            fi
        else
            echo "error"; rm -f "$TEMP_FILE"; exit 1
        fi
    ) | zenity --progress --title="SotoHome Updater" --text="Initializing update..." --percentage=0 --auto-close --no-cancel --width=400
    
    if [ ${PIPESTATUS[0]} -eq 0 ]; then
        gui_info "SotoHome has been successfully updated!\n\nAll launcher actions have been refreshed." "SotoHome Updater"
        mv "$TEMP_FILE" "$SCRIPT_PATH" || { rm -f "$TEMP_FILE"; exit 1; }
        chmod +x "$SCRIPT_PATH"
        exec "$SCRIPT_PATH" --install --silent
    else
        gui_error "Failed to download or verify the update.\n\nPlease check your internet connection or repository variables."
        rm -f "$TEMP_FILE" 2>/dev/null
    fi
    exit 0
}

# =============================================================================
# CLI Dispatcher
# =============================================================================
if [ "$1" == "--install" ]; then do_install "$@"; fi
if [ "$1" == "--update" ]; then do_update; fi
if [ "$1" == "--bitrate" ]; then do_bitrate; fi # Falls through intentionally

GPU_MODE=false
if [ "$1" == "--gpu" ]; then GPU_MODE=true; fi

# =============================================================================
# Core Application Functions
# =============================================================================
setup_progress_window() {
    PIPE=$(mktemp -u /tmp/sotohome.XXXXXX)
    mkfifo "$PIPE"
    zenity --progress --title="SotoHome Launcher" --text="Initializing..." --percentage=0 --auto-close --no-cancel --width=400 < "$PIPE" &
    ZEN_PID=$!
    exec 3> "$PIPE"
}

update_progress() {
    if [ -n "${ZEN_PID:-}" ] && kill -0 "$ZEN_PID" 2>/dev/null; then
        echo "$1" >&3 2>/dev/null
        echo "# $2" >&3 2>/dev/null
    fi
}

cleanup_and_disconnect() {
    exec 3>&- 2>/dev/null
    [ -n "$PIPE" ] && rm -f "$PIPE" 2>/dev/null
    [ -f "$PID_FILE" ] && [ "$(cat "$PID_FILE" 2>/dev/null)" == "$$" ] && rm -f "$PID_FILE" 2>/dev/null
    if nmcli con show --active | grep -q "$VPN_NAME"; then
        nmcli connection down "$VPN_NAME" >/dev/null 2>&1
    fi
}

connect_vpn_and_wait() {
    update_progress 10 "Activating VPN Connection..."
    if ! nmcli connection up "$VPN_NAME" >/dev/null 2>&1; then
        gui_error "Failed to connect to VPN."
        exit 1
    fi

    update_progress 25 "Waiting for Server to Respond..."
    local WAIT_COUNT=0
    while ! ping -c 1 -W 1 "$SERVER_IP" > /dev/null 2>&1; do
        sleep 1
        WAIT_COUNT=$((WAIT_COUNT + 1))
        if [ "$WAIT_COUNT" -ge 15 ]; then
            gui_error "Connected to VPN, but server $SERVER_IP is unreachable."
            exit 1
        fi
    done
}

handle_gpu_state() {
    update_progress 35 "Awaiting GPU Configuration..."
    local GPU_ACTION=$(zenity --list --title="GPU Power Control" \
        --text="Select GPU State (Server will reboot if state changes):" \
        --radiolist --column="Select" --column="Action" \
        TRUE "GPU On" FALSE "GPU Off" --width=300 --height=200)

    [ -z "$GPU_ACTION" ] && exit 0

    local HOOK_PATH=$([ "$GPU_ACTION" == "GPU On" ] && echo "gpu-on" || echo "gpu-off")

    update_progress 40 "Sending GPU command..."
    curl -s -m 10 "http://$SERVER_IP:$WEBHOOK_PORT/hooks/$HOOK_PATH" > /dev/null
    sleep 4

    if ping -c 1 -W 1 "$SERVER_IP" >/dev/null 2>&1 && \
       curl -s -m 2 "http://$SERVER_IP:$WEBHOOK_PORT/hooks/check-session" >/dev/null 2>&1 && \
       (timeout 1 bash -c "cat < /dev/null > /dev/tcp/$SERVER_IP/47989") >/dev/null 2>&1; then
        update_progress 45 "GPU state already matched. Skipping reboot sequence..."
        sleep 2
    else
        update_progress 45 "Server reboot detected. Disconnecting VPN..."
        nmcli con show --active | grep -q "$VPN_NAME" && nmcli connection down "$VPN_NAME" >/dev/null 2>&1

        local SERVER_READY=false
        local TOTAL_REBOOT_TIME=70
        
        for ((i=1; i<=TOTAL_REBOOT_TIME; i++)); do
            local REMAINING=$((TOTAL_REBOOT_TIME - i))
            local PERCENT=$(( 45 + (i * 40 / TOTAL_REBOOT_TIME) ))

            kill -0 "$ZEN_PID" 2>/dev/null || exit 1

            if [ "$i" -lt 40 ]; then
                update_progress "$PERCENT" "Waiting for server to reboot... (Est. $REMAINING seconds remaining)"
                sleep 1
            else
                update_progress "$PERCENT" "Reconnecting VPN & waiting for server response... ($REMAINING seconds remaining)"
                nmcli con show --active | grep -q "$VPN_NAME" || nmcli connection up "$VPN_NAME" >/dev/null 2>&1

                if ping -c 1 -W 1 "$SERVER_IP" >/dev/null 2>&1 && \
                   curl -s -m 2 "http://$SERVER_IP:$WEBHOOK_PORT/hooks/check-session" >/dev/null 2>&1 && \
                   (timeout 1 bash -c "cat < /dev/null > /dev/tcp/$SERVER_IP/47989") >/dev/null 2>&1; then
                    sleep 3
                    SERVER_READY=true
                    break
                fi
                sleep 1
            fi
        done

        if [ "$SERVER_READY" = false ]; then
            gui_error "Server failed to come online within the 70-second window."
            exit 1
        fi
    fi

    # Global overrides bypass conflict resolution
    TARGET_SESSION="Gaming"
    START_NEW_SESSION=true
}

select_target_session() {
    TARGET_SESSION="Gaming"
    if [ "$1" == "--admin" ]; then
        update_progress 40 "Awaiting Admin Session Selection..."
        TARGET_SESSION=$(zenity --list --title="Select Session" \
            --text="Which session would you like to start?" \
            --radiolist --column="Select" --column="Session Type" \
            TRUE "Gaming" FALSE "KDE" --width=300 --height=200)

        [ -z "$TARGET_SESSION" ] && exit 0

        if [ "$TARGET_SESSION" == "KDE" ] && [ -z "$SSH_ALIAS" ]; then
            gui_info "SSH_ALIAS is empty in the script.\nYou cannot start a KDE session without it.\n\nFalling back to Gaming mode." "Missing SSH Alias"
            TARGET_SESSION="Gaming"
        fi
    fi
}

check_session() {
    local status=$(curl -s -m 5 "http://$SERVER_IP:$WEBHOOK_PORT/hooks/check-session" 2>/dev/null)
    if echo "$status" | grep -iq "KDE"; then echo "KDE";
    elif echo "$status" | grep -iq "Gaming"; then echo "Gaming";
    else echo "None"; fi
}

verify_local_sudo() {
    if command -v pkexec >/dev/null 2>&1; then
        gui_info "A KDE session is running remotely.\n\nYou will now be prompted for your LOCAL system password to authorize termination." "Admin Required"
        pkexec true
        return $?
    else
        local pass=$(zenity --password --title="Local Sudo Required" --text="Enter your LOCAL system password to authorize termination:")
        [ -n "$pass" ] && echo "$pass" | sudo -S -v >/dev/null 2>&1
        return $?
    fi
}

resolve_session_conflict() {
    update_progress 55 "Checking Server Session Status..."
    local ACTIVE_SESSION=$(check_session)
    START_NEW_SESSION=true

    if [ "$ACTIVE_SESSION" != "None" ]; then
        update_progress 65 "Handling Active Session Conflict..."
        if zenity --question --title="Session Conflict" --text="A $ACTIVE_SESSION session is already active.\n\nDo you want to TERMINATE it and start a fresh session?\n\n(Click 'No' to keep and stream the existing session)"; then
            update_progress 70 "Terminating remote $ACTIVE_SESSION session..."
            if ! stop_remote_session "$ACTIVE_SESSION"; then
                gui_error "Local authorization failed. Resuming the existing session instead."
                START_NEW_SESSION=false
                TARGET_SESSION="$ACTIVE_SESSION"
            fi
        else
            START_NEW_SESSION=false
            TARGET_SESSION="$ACTIVE_SESSION"
        fi
    fi
}

stop_remote_session() {
    if [ "$1" == "KDE" ] && ! verify_local_sudo; then return 1; fi
    while read -r line; do
        case "$line" in
            *"Stopping Sunshine"*) update_progress 73 "$line" ;;
            *"Waiting for session to close"*) update_progress 76 "$line" ;;
            *"Session closed"*) update_progress 80 "$line" ;;
            *"Waiting for SDDM greeter"*) update_progress 82 "$line" ;;
            *"Starting Sunshine"*) update_progress 84 "$line" ;;
            *"✓ Session ended"*) update_progress 85 "$line"; break ;;
        esac
    done < <(curl -sN -m 60 "http://$SERVER_IP:$WEBHOOK_PORT/hooks/stop-session" 2>&1)
}

start_remote_gaming() {
    while read -r line; do
        case "$line" in
            *"Stopping SDDM"*) update_progress 87 "$line" ;;
            *"Starting SDDM"*) update_progress 90 "$line" ;;
            *"Waiting for Gamescope"*) update_progress 93 "$line" ;;
            *"session detected"*) update_progress 95 "$line" ;;
            *"Starting Sunshine"*) update_progress 98 "$line" ;;
            *"✓ Gaming Mode"*) update_progress 100 "$line"; break ;;
        esac
    done < <(curl -sN -m 180 "http://$SERVER_IP:$WEBHOOK_PORT/hooks/start-gaming" 2>&1)
}

start_remote_kde() {
    while read -r line; do
        case "$line" in
            *"Stopping SDDM"*) update_progress 87 "$line" ;;
            *"Starting SDDM"*) update_progress 90 "$line" ;;
            *"Waiting for KDE"*) update_progress 93 "$line" ;;
            *"is active"*) update_progress 95 "$line" ;;
            *"Starting Sunshine"*) update_progress 98 "$line" ;;
            *"✓ KDE Plasma"*) update_progress 100 "$line"; break ;;
        esac
    done < <(setsid -w ssh "$SSH_ALIAS" "sudo start-kde" < /dev/null 2>&1)
}

start_requested_session() {
    if [ "$START_NEW_SESSION" = true ]; then
        if [ "$TARGET_SESSION" == "KDE" ]; then
            update_progress 85 "Starting remote KDE session..."
            start_remote_kde
        else
            local pct=$([ "$GPU_MODE" = true ] && echo 85 || echo 80)
            update_progress $pct "Triggering remote Gaming session..."
            start_remote_gaming
        fi
    else
        update_progress 85 "Preparing to resume $TARGET_SESSION session..."
    fi
}

launch_moonlight() {
    update_progress 100 "Ready! Launching Moonlight Stream..."
    sleep 0.5
    exec 3>&-
    rm -f "$PIPE"

    if command -v flatpak >/dev/null 2>&1 && flatpak info com.moonlight_stream.Moonlight >/dev/null 2>&1; then
        flatpak run com.moonlight_stream.Moonlight stream --bitrate "$BITRATE" "$SERVER_IP" "$APP_NAME"
    else
        moonlight stream --bitrate "$BITRATE" "$SERVER_IP" "$APP_NAME"
    fi
}

prompt_exit_cleanup() {
    local FINAL_SESSION=$(check_session)
    if [ "$FINAL_SESSION" != "None" ]; then
        if zenity --question --title="Stream Closed" --text="Moonlight closed.\n\nDo you want to terminate the active $FINAL_SESSION session?"; then
            if stop_remote_session "$FINAL_SESSION"; then
                gui_notify "Server session terminated."
            else
                gui_notify "Authorization failed. Server session left active."
            fi
        else
            gui_notify "Server session left active."
        fi
    fi
}

# =============================================================================
# Main Execution Flow
# =============================================================================
trap cleanup_and_disconnect EXIT INT TERM

setup_progress_window
connect_vpn_and_wait

if [ "$GPU_MODE" = true ]; then
    handle_gpu_state
else
    select_target_session "$1"
    resolve_session_conflict
fi

start_requested_session
launch_moonlight
prompt_exit_cleanup

exit 0
